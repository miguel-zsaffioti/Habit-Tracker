from fastapi import FastAPI, Depends
from fastapi.middleware.cors import CORSMiddleware
from sqlalchemy.orm import Session

# Importamos a Base, a engine e o model que acabamos de criar
import models
from database import engine, get_db

# Isso faz o SQLAlchemy criar as tabelas no Postgres se elas não existirem
models.Base.metadata.create_all(bind=engine)

app = FastAPI()

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=False, # Alterado para False conforme combinamos
    allow_methods=["*"],
    allow_headers=["*"],
)

@app.get("/")
def read_root():
    return {"status": "Backend e Postgres conectados com sucesso!"}

# Rota de teste para ver se o banco está funcionando
@app.get("/test-db")
def test_db_connection(db: Session = Depends(get_db)):
    return {"mensagem": "Se você chegou aqui sem erros, o banco de dados está funcionando perfeitamente!"}